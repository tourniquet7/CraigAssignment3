<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FISSystem.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FISSystem"
    xmlns:pages="clr-namespace:FISSystem.Pages"
    Title="FISSystem">


    <TabBar>
        <Tab Title="Accounts Payable">
            <ShellContent ContentTemplate="{DataTemplate pages:AccountsPayable}" />
        </Tab>

        <Tab Title="Accounts Receivable">
            <ShellContent ContentTemplate="{DataTemplate pages:AccountsReceivable}" />
        </Tab>
    </TabBar>

</Shell>
